# OpenAI-compatible API (LLM / STT / TTS)
# ⚠️ 配置文件名必须是 .env（不是 .env.local）
# 复制本文件: cp .env.example .env
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Groq 示例:
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# DeepSeek 示例:
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=sk-...
# LLM_MODEL=deepseek-chat

# Gemini 示例 (需可访问 Google 网络):
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_API_KEY=AIza...   # Google AI Studio 密钥，通常以 AIza 开头
# LLM_MODEL=gemini-2.0-flash

# DeepSeek 示例 (国内推荐):
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=sk-...
# LLM_MODEL=deepseek-chat

# 通义千问 示例 (国内推荐):
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY=sk-...
# LLM_MODEL=qwen-plus

# Model selection
LLM_MODEL=gpt-4o-mini
CORRECTION_MODEL=gpt-4o-mini
# DeepSeek 不支持 STT/TTS，语音转文字需单独配置（推荐 Groq Whisper）:
# STT_API_KEY=gsk_你的Groq密钥
# STT_BASE_URL=https://api.groq.com/openai/v1
# STT_MODEL=whisper-large-v3
TTS_MODEL=tts-1
TTS_VOICE=alloy

# Coach & correction tuning
COACH_TEMPERATURE=0.75
COACH_MAX_TOKENS=256
CORRECTION_TEMPERATURE=0.2
CORRECTION_MAX_TOKENS=512

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# Session
MAX_SESSION_TURNS=30
