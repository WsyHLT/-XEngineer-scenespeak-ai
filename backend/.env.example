# OpenAI-compatible API (LLM — DeepSeek 等)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek via 百炼（国内低延迟，推荐）:
# OPENAI_API_KEY=sk-your-dashscope-api-key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=deepseek-v4-flash
# CORRECTION_MODEL=deepseek-v4-flash
# LLM_ENABLE_THINKING=false

# DeepSeek 官网 API（需能访问 api.deepseek.com）:
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-v4-flash
# CORRECTION_MODEL=deepseek-v4-flash

LLM_MODEL=gpt-4o-mini
CORRECTION_MODEL=gpt-4o-mini

# ── 路线 B · 听：百炼 ASR ──
# 推荐 Paraformer（多数账号默认可用，无需单独开通 Qwen-ASR）
STT_PROVIDER=dashscope
STT_API_KEY=sk-your-dashscope-api-key
STT_DASHSCOPE_MODEL=paraformer-realtime-v2
STT_LANGUAGE_HINTS=en
STT_MAX_SENTENCE_SILENCE=1500

# 若已开通 Qwen-ASR Realtime（模型广场搜索 qwen3-asr-flash-realtime）：
# STT_PROVIDER=bailian
# STT_MODEL=qwen3-asr-flash-realtime
# BAILIAN_ASR_LANGUAGE=en

# SenseVoice 本地 ASR 备选:
# STT_PROVIDER=sensevoice
# SENSEVOICE_MODEL=iic/SenseVoiceSmall
# SENSEVOICE_DEVICE=cpu
# SENSEVOICE_LANGUAGE=en

# Paraformer 云端备选:
# STT_PROVIDER=dashscope
# STT_MODEL=paraformer-realtime-v2
# STT_LANGUAGE_HINTS=en

# ── 路线 B · 评测：腾讯云智聆 SOE（新版 WebSocket）──
PRONUNCIATION_PROVIDER=tencent
TENCENT_APP_ID=你的腾讯云APPID
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SOE_ENGINE=16k_en
TENCENT_SCORE_COEFF=1.0
# APPID 在 https://console.cloud.tencent.com/cam/capi 表格第一列

# Azure 发音评测备选:
# PRONUNCIATION_PROVIDER=azure
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus
# AZURE_PRONUNCIATION_LANGUAGE=en-US

# ── 路线 B · 说：火山引擎 TTS ──
TTS_PROVIDER=volcano
VOLCANO_APP_ID=
VOLCANO_ACCESS_TOKEN=
VOLCANO_CLUSTER=volcano_tts
VOLCANO_VOICE_TYPE=BV700_streaming
VOLCANO_AUDIO_ENCODING=mp3
VOLCANO_SPEED_RATIO=1.0

# OpenAI TTS 备选:
# TTS_PROVIDER=openai
# TTS_MODEL=tts-1
# TTS_VOICE=alloy

COACH_TEMPERATURE=0.75
COACH_MAX_TOKENS=256
CORRECTION_TEMPERATURE=0.2
CORRECTION_MAX_TOKENS=512

HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000
MAX_SESSION_TURNS=30
